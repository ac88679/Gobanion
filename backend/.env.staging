# Gobanion – Staging Environment
# ═══════════════════════════════════════════════════════════════════
# Committed to git。预发布环境，接近生产但保留 DEBUG。

APP_ENV=staging
DEBUG=true

# Staging LLM（同本地模型，temperature 略高用于探索）
LLM_API_BASE=http://localhost:8000/v1
LLM_MODEL=Qwen3.5-9B
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.8
