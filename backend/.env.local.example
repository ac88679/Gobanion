# ═══════════════════════════════════════════════════════════════════
# Gobanion – Local Overrides Template (never committed)
# ═══════════════════════════════════════════════════════════════════
# Copy to .env.local and fill in your local values.
# These override .env.shared → .env.{ENV} → .env.local.
#
# Priority: .env.shared < .env.{APP_ENV} < .env.local < OS env vars

# ── LLM Endpoint ──
# Override if your local LLM runs on a different host/port
LLM_API_BASE=http://localhost:8000/v1

# ── LLM Model ──
# Override if you use a different local model than the default
LLM_MODEL=Qwen3.5-9B

# ── LLM Max Tokens ──
# Override to match your local model's context window
# LLM_MAX_TOKENS=24000

# ── LLM API Key (if your endpoint requires auth) ──
# LLM_API_KEY=sk-your-key-here

# ── Fallback / Public Model (主 Agent 规划用) ──
# LLM_FALLBACK_KEY=sk-your-deepseek-key
# LLM_FALLBACK_MODEL=deepseek-v4-flash
# LLM_FALLBACK_BASE=https://api.deepseek.com

# ── Local DB override ──
# DATABASE_URL=sqlite:///./gobanion_dev.db

# ── Debug ──
# DEBUG=true
