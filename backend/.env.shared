# ═══════════════════════════════════════════════════════════════════
# Gobanion – Shared Environment (committed to git)
# ═══════════════════════════════════════════════════════════════════
# Values shared across all environments. Override in .env.{ENV} or
# .env.local when a specific environment needs a different value.

# ── App ──
APP_NAME=Gobanion
APP_VERSION=0.1.0

# ── HTTP Server ──
HOST=0.0.0.0
PORT=5000
CORS_ORIGINS=["*"]

# ── Database ──
DATABASE_URL=sqlite:///./gobanion.db
DATABASE_ECHO=false

# ── LLM (default: local vLLM / Ollama) ──
LLM_API_BASE=http://localhost:8000/v1
LLM_API_KEY=
LLM_MODEL=Qwen3.5-9B
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# ── Fallback / public model (主 Agent 规划用) ──
LLM_FALLBACK_BASE=https://api.deepseek.com
LLM_FALLBACK_KEY=
LLM_FALLBACK_MODEL=deepseek-v4-flash
LLM_FALLBACK_MAX_TOKENS=16384

# ── Agent ──
AGENT_DISPATCHER_TIMEOUT=30
AGENT_HEARTBEAT_INTERVAL=10
AGENT_MAX_RETRIES=3
