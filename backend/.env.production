# ═══════════════════════════════════════════════════════════════════
# Gobanion – Production Environment
# ═══════════════════════════════════════════════════════════════════
# Committed to git.
# Secrets (API keys, tokens) 通过 OS env vars 注入，不在此文件中。

APP_ENV=production
DEBUG=false

# 生产环境 LLM（较低 temperature，更确定性的输出）
LLM_API_BASE=http://localhost:8000/v1
LLM_MODEL=Qwen3.5-9B
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.3

# 公开模型（主 Agent 规划用）
LLM_FALLBACK_BASE=https://api.deepseek.com
LLM_FALLBACK_MODEL=deepseek-v4-flash
LLM_FALLBACK_MAX_TOKENS=16384
